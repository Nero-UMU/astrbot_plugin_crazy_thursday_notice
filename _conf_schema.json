{
  "group_ids": {
    "type": "list",
    "description": "要推送消息的 QQ 群号列表",
    "default": []
  },
  "push_days": {
    "type": "list",
    "description": "每周推送日期（可多选）",
    "default": ["周四"],
    "options": ["周一", "周二", "周三", "周四", "周五", "周六", "周日"]
  },
  "push_times": {
    "type": "list",
    "description": "每天推送时间（可多选）",
    "default": ["12:00"],
    "options": ["08:00", "10:00", "11:00", "12:00", "14:00", "16:00", "18:00", "20:00", "22:00"]
  },
  "message": {
    "type": "string",
    "description": "推送的文案（菜单会自动附在后面）",
    "default": "今天是肯德基疯狂星期四！V我50！"
  },
  "mcd_token": {
    "type": "string",
    "description": "麦当劳 MCP Token（在 open.mcd.cn 注册后获取）",
    "default": ""
  },
  "city": {
    "type": "string",
    "description": "定位城市，用于拉取附近 KFC 菜单",
    "default": "上海",
    "options": ["上海", "北京", "广州", "深圳", "杭州", "成都", "武汉", "南京", "西安", "重庆", "天津", "苏州", "郑州", "长沙", "青岛", "厦门", "南昌", "合肥", "哈尔滨", "沈阳"]
  }
}
