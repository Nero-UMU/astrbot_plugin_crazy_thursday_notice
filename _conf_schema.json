{
  "group_ids": {
    "type": "list",
    "description": "要推送消息的 QQ 群号列表",
    "default": []
  },
  "push_days": {
    "type": "list",
    "description": "每周推送日期（可多选）",
    "default": ["周四"],
    "options": ["周一", "周二", "周三", "周四", "周五", "周六", "周日"]
  },
  "push_times": {
    "type": "list",
    "description": "每天推送时间（可多选）",
    "default": ["12:00"],
    "options": ["08:00", "10:00", "11:00", "12:00", "14:00", "16:00", "18:00", "20:00", "22:00"]
  },
  "message": {
    "type": "string",
    "description": "推送的文案（菜单会自动附在后面）",
    "default": "今天是肯德基疯狂星期四！V我50！"
  },
  "mcd_token": {
    "type": "string",
    "description": "麦当劳 MCP Token（在 open.mcd.cn 注册后获取）",
    "default": ""
  },
  "mcd_store_code": {
    "type": "string",
    "description": "麦当劳门店编号（留空则自动根据城市查找）",
    "default": ""
  },
  "mcd_order_type": {
    "type": "string",
    "description": "点单类型：1=堂食，2=外卖",
    "default": "1",
    "options": ["1", "2"]
  },
  "city": {
    "type": "string",
    "description": "定位城市，用于拉取附近 KFC/麦当劳菜单",
    "default": "上海市",
    "options": ["上海市", "北京市", "广州市", "深圳市", "杭州市", "成都市", "武汉市", "南京市", "西安市", "重庆市", "天津市", "苏州市", "郑州市", "长沙市", "青岛市", "厦门市", "南昌市", "合肥市", "哈尔滨市", "沈阳市"]
  }
}
